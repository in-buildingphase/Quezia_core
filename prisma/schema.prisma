// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  username     String    @unique
  email        String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastLogin    DateTime? @map("last_login")
  isActive     Boolean   @default(true) @map("is_active")

  profile       UserProfile?
  subscriptions Subscription[]
  tests         Test[]

  @@map("users")
}

model UserProfile {
  userId String @id @map("user_id") @db.Uuid

  // identity
  displayName String? @map("display_name")
  country     String?
  timezone    String?

  // account tier
  accountTier AccountTier @default(free) @map("account_tier")

  // active exam context
  activeExamId   String? @map("active_exam_id") @db.Uuid
  activeExamYear Int?    @map("active_exam_year")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Subscription {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @db.Uuid
  examId          String             @db.Uuid
  year            Int
  status          SubscriptionStatus
  startedAt       DateTime
  expiresAt       DateTime
  paymentProvider String
  providerRef     String

  user User @relation(fields: [userId], references: [id])
  exam Exam @relation(fields: [examId], references: [id])

  @@index([userId, examId])
}

model Exam {
  id       String  @id @default(uuid()) @db.Uuid
  name     String
  isActive Boolean @default(true)

  blueprints    ExamBlueprint[]
  subscriptions Subscription[]
  tests         Test[]
}

model ExamBlueprint {
  id        String   @id @default(uuid()) @db.Uuid
  examId    String   @db.Uuid
  version   String // "2024", "2025"
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)

  exam     Exam                   @relation(fields: [examId], references: [id])
  sections ExamBlueprintSection[]
  rules    ExamRule[]
  tests    Test[]

  @@unique([examId, version])
}

model ExamBlueprintSection {
  id          String @id @default(uuid()) @db.Uuid
  blueprintId String @db.Uuid
  name        String // Reading, Listening
  sequence    Int

  blueprint     ExamBlueprint     @relation(fields: [blueprintId], references: [id])
  sectionRules  ExamSectionRule[]
  testSections  TestSection[]
  testQuestions TestQuestion[]

  @@unique([blueprintId, sequence])
}

model ExamRule {
  id               String    @id @default(uuid()) @db.Uuid
  blueprintId      String    @db.Uuid
  totalTimeSeconds Int
  negativeMarking  Boolean
  partialMarking   Boolean
  adaptiveAllowed  Boolean
  effectiveFrom    DateTime  @db.Date
  effectiveTo      DateTime? @db.Date

  blueprint ExamBlueprint @relation(fields: [blueprintId], references: [id])
  tests     Test[]

  @@index([blueprintId, effectiveFrom, effectiveTo])
}

model ExamSectionRule {
  id                 String @id @default(uuid()) @db.Uuid
  blueprintSectionId String @db.Uuid
  timeLimitSeconds   Int
  maxQuestions       Int
  markingScheme      Json

  blueprintSection ExamBlueprintSection @relation(fields: [blueprintSectionId], references: [id])
}

model Test {
  id              String     @id @default(uuid()) @db.Uuid
  userId          String     @db.Uuid
  examId          String     @db.Uuid
  examYear        Int
  examBlueprintId String     @db.Uuid
  examRuleId      String     @db.Uuid
  status          TestStatus
  isRetake        Boolean    @default(false)
  startedAt       DateTime
  completedAt     DateTime?

  user      User          @relation(fields: [userId], references: [id])
  exam      Exam          @relation(fields: [examId], references: [id])
  blueprint ExamBlueprint @relation(fields: [examBlueprintId], references: [id])
  rule      ExamRule      @relation(fields: [examRuleId], references: [id])

  sections  TestSection[]
  questions TestQuestion[]
  result    TestResult?

  @@index([userId, examId, examYear])
}

model TestSection {
  id                 String @id @default(uuid()) @db.Uuid
  testId             String @db.Uuid
  blueprintSectionId String @db.Uuid
  timeLimitSeconds   Int
  sequence           Int

  test             Test                 @relation(fields: [testId], references: [id])
  blueprintSection ExamBlueprintSection @relation(fields: [blueprintSectionId], references: [id])

  @@unique([testId, sequence])
}

model TestQuestion {
  id                 String @id @default(uuid()) @db.Uuid
  testId             String @db.Uuid
  questionId         String // immutable Quezia Question ID
  blueprintSectionId String @db.Uuid
  position           Int

  test             Test                 @relation(fields: [testId], references: [id])
  blueprintSection ExamBlueprintSection @relation(fields: [blueprintSectionId], references: [id])
  answer           TestAnswer?

  @@unique([testId, position])
  @@index([questionId])
}

model TestAnswer {
  testQuestionId   String  @id @db.Uuid
  finalAnswer      Json
  timeSpentSeconds Int
  isCorrect        Boolean

  testQuestion TestQuestion @relation(fields: [testQuestionId], references: [id])
}

model TestResult {
  testId          String   @id @db.Uuid
  rawScore        Float
  normalizedScore Float
  computedAt      DateTime @default(now())

  test Test @relation(fields: [testId], references: [id])
}

enum AccountTier {
  free
  paid
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}

enum TestStatus {
  active
  completed
  abandoned
}
